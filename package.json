{
  "name": "warehouse-crm",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "server": "npm run backend & npm run frontend",
    "frontend": "npm run dev --workspace apps/web",
    "backend": "npm run dev --workspace apps/api",
    "backend:start": "npm run start --workspace apps/api",
    "build:web": "npm run build --workspace apps/web",
    "preview:web": "npm run preview --workspace apps/web",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "test:backend": "npm run test --workspace apps/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.2.1",
    "typescript": "^5.9.3"
  }
}
